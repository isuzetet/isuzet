# RUIT CBE Production Environment Configuration
# Required environment variables for June 4, 2026 launch
# Copy this file and fill in actual values before deployment

# ========== DATABASE ==========
DATABASE_URL="postgresql://user:password@production-db.example.com:5432/ruit_cbe"
TIMESCALE_URL="postgresql://user:password@timescale.example.com:5432/ruit_timescale"
DATABASE_POOL_SIZE="30"  # Will be auto-scaled based on CPU count, this is a fallback

# ========== AUTHENTICATION ==========
JWT_SECRET="your-super-secret-jwt-key-min-32-chars"
JWT_EXPIRE="15m"  # Access token expiry
JWT_REFRESH_EXPIRE="30d"  # Refresh token expiry
WEBHOOK_SECRET="webhook-signature-secret-key"
INTERNAL_SECRET="system-internal-secret-key"

# ========== EXTERNAL SERVICES ==========
# SMS Providers
AFRICAS_TALKING_API_KEY="your-africas-talking-api-key"
AFRICAS_TALKING_USERNAME="your-africas-talking-username"
TWILIO_ACCOUNT_SID="your-twilio-account-sid"
TWILIO_AUTH_TOKEN="your-twilio-auth-token"

# Firebase Admin SDK
FIREBASE_SERVICE_ACCOUNT_PATH="/etc/secrets/firebase-service-account.json"
# OR use Google Application Credentials instead
GOOGLE_APPLICATION_CREDENTIALS="/etc/secrets/google-credentials.json"

# Payment Integration
CHAPA_API_KEY="your-chapa-api-key"
CHAPA_SECRET="your-chapa-secret"
TELEBIRR_MERCHANT_ID="your-telebirr-merchant-id"
TELEBIRR_API_KEY="your-telebirr-api-key"

# ========== CACHING & QUEUES ==========
REDIS_URL="redis://production-redis.example.com:6379"
REDIS_PASSWORD="redis-password"
REDIS_TLS=true

# BullMQ Job Queue
BULL_QUEUE_NAME="ruit_cbe_jobs"
BULL_MAX_RETRIES="3"

# ========== MICROSERVICES ==========
# Service ports
PORT_IDENTITY=3001
PORT_DISPATCH=3002
PORT_FLEET=3003
PORT_DATA=3004
PORT_LOCATION=3005
PORT_OPTIMIZER=3006
PORT_LIQUIDITY=3007
PORT_NOTIFICATION=3013
PORT_INCIDENT=3011
PORT_BEHAVIOR=3010
PORT_CORRIDOR=3009
PORT_STRATEGY=3008
PORT_HEALTH=3012
PORT_SHOCK=3014
PORT_TWIN=3015

# Service base URLs for inter-service communication
SERVICE_IDENTITY_URL="http://identity:3001"
SERVICE_DISPATCH_URL="http://dispatch:3002"
SERVICE_FLEET_URL="http://fleet:3003"
SERVICE_LOCATION_URL="http://location:3005"
SERVICE_OPTIMIZER_URL="http://optimizer:3006"
SERVICE_LIQUIDITY_URL="http://liquidity:3007"
SERVICE_NOTIFICATION_URL="http://notification:3013"

# ========== MONITORING & OBSERVABILITY ==========
NODE_ENV="production"
APP_VERSION="1.0.0"
LOG_LEVEL="info"  # debug, info, warn, error
DEBUG=false

# Correlation ID tracing
ENABLE_CORRELATION_ID_LOGGING=true

# Health check settings
HEALTH_CHECK_INTERVAL_MS=30000  # 30 seconds
HEALTH_CHECK_TIMEOUT_MS=5000    # 5 seconds

# ========== RATE LIMITING & THROTTLING ==========
RATE_LIMIT_WINDOW_MS=60000  # 1 minute
RATE_LIMIT_MAX_REQUESTS=100
RATE_LIMIT_MAX_REQUESTS_AUTH=10  # Stricter for auth endpoints

# ========== GRACEFUL SHUTDOWN ==========
GRACEFUL_SHUTDOWN_TIMEOUT_MS=30000  # 30 seconds
GRACEFUL_SHUTDOWN_SIGNAL="SIGTERM"

# ========== FEATURE FLAGS ==========
ENABLE_SMS_NOTIFICATIONS=true
ENABLE_PUSH_NOTIFICATIONS=true
ENABLE_EMAIL_NOTIFICATIONS=false
ENABLE_TELEGRAM_INTEGRATION=true
ENABLE_OFFLINE_SYNC=true
ENABLE_GPS_TRACKING=true
ENABLE_INCIDENT_ESCALATION=true

# ========== SECURITY ==========
CORS_ORIGIN="https://app.isuzet.com"
API_KEY_ROTATION_DAYS=90
SESSION_TIMEOUT_MINUTES=60
MAX_LOGIN_ATTEMPTS=5
LOGIN_ATTEMPT_WINDOW_MINUTES=15

# ========== DEPLOYMENT METADATA ==========
DEPLOYMENT_DATE="2026-06-04"
DEPLOYMENT_ENV="production"
DEPLOYMENT_REGION="africa"
DEPLOYMENT_VERSION="1.0.0-launch"
