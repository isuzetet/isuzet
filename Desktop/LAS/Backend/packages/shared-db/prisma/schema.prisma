model CorridorBalancingEvent {
  id                      String    @id @default(cuid()) @db.VarChar(26)

  corridorId              String    @db.VarChar(26)
  // The corridor experiencing the imbalance

  detectedAt              DateTime  @default(now())
  // When the optimizer detected this imbalance

  imbalanceDirection      String
  // Values from CorridorImbalanceDirection:
  // OUTBOUND_SURPLUS | INBOUND_SURPLUS | BILATERAL_DEFICIT | BILATERAL_SURPLUS

  outboundAvailableTrucks Int       @default(0)
  // Number of trucks available or heading outbound

  inboundAvailableTrucks  Int       @default(0)
  // Number of trucks available or heading inbound

  outboundPendingLoads    Int       @default(0)
  // Number of loads waiting for trucks, outbound direction

  inboundPendingLoads     Int       @default(0)
  // Number of loads waiting for trucks, inbound direction

  imbalanceScore          Decimal   @db.Decimal(5, 2)
  // Composite score 0-100 measuring severity of imbalance
  // 0 = perfectly balanced, 100 = severe imbalance

  interventionType        String?
  // Values from BalancingInterventionType enum
  // Null if imbalance was detected but no intervention taken

  interventionAppliedAt   DateTime?

  priceIncentivePct       Decimal?  @db.Decimal(5, 2)
  // If interventionType = PRICE_INCENTIVE:
  // % increase applied to underserved direction rate

  driversNotifiedCount    Int       @default(0)
  // If DRIVER_NOTIFICATION or BACKHAUL_NUDGE:
  // How many drivers received the notification

  loadsConsolidated       Int       @default(0)
  // If LOAD_CONSOLIDATION: how many loads were consolidated

  resolvedAt              DateTime?
  // When the imbalance was resolved (supply/demand returned to balance)

  resolutionNotes         String?
  // What ultimately resolved the imbalance

  interventionEffective   Boolean?
  // True = intervention measurably helped resolve the imbalance
  // False = intervention did not help (used for strategy learning)
  // Null = too early to determine

  @@index([corridorId, detectedAt])
  @@index([imbalanceDirection, detectedAt])
  @@index([interventionType])
  @@map("corridor_balancing_events")
}

