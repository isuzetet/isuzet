generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                           String        @id @db.VarChar(26)
  phone                        String        @unique
  phoneBackup                  String?       @map("phone_backup")
  email                        String?
  fullName                     String        @map("full_name")
  fullNameAmharic              String?       @map("full_name_amharic")
  role                         String
  status                       String        @default("PENDING_KYC")
  kycTier                      Int           @default(0) @map("kyc_tier")
  preferredLanguage            String        @default("am") @map("preferred_language")
  notificationChannel          String        @default("SMS") @map("notification_channel")
  lastLoginAt                  DateTime?     @map("last_login_at")
  lastLoginIp                  String?       @map("last_login_ip")
  deviceIdPrimary              String?       @map("device_id_primary")
  deviceIdSecondary            String?       @map("device_id_secondary")
  linkedAccountIds             String[]      @default([]) @map("linked_account_ids")
  accountType                  String        @default("PERSONAL") @map("account_type")
  referralCode                 String?       @unique @map("referral_code")
  referredByCode               String?       @map("referred_by_code")
  isOwnerOperator              Boolean       @default(false) @map("is_owner_operator")
  simNameMismatch              Boolean       @default(false) @map("sim_name_mismatch")
  deletedAt                    DateTime?     @map("deleted_at")
  createdAt                    DateTime      @default(now()) @map("created_at")
  updatedAt                    DateTime      @updatedAt @map("updated_at")
  dataConsentGiven             Boolean       @default(false) @map("data_consent_given")
  dataConsentGivenAt           DateTime?     @map("data_consent_given_at")
  notificationThrottledUntil   DateTime?     @map("notification_throttled_until")
  telegramHandle               String?       @map("telegram_handle")
  telegramId                   String?       @unique @map("telegram_id")
  telegramLinkedAt             DateTime?     @map("telegram_linked_at")
  telegramNotificationsEnabled Boolean       @default(false) @map("telegram_notifications_enabled")
  fcmToken                     String?       @map("fcm_token")
  preferredPaymentRail         String?
  paymentPhone                 String?       @map("payment_phone")
  // Values from PaymentRailType enum: TELEBIRR | CBE_BIRR | AMOLE | HELLOCASH | AWASH_WALLET | BANK_TRANSFER
  // Null = user has not set a preference yet
  agentClients                 AgentClient[] @relation("AgentToClients")
  clientAgentRels              AgentClient[] @relation("ClientToAgents")
  agentPostedLoads             Load[]        @relation("AgentLoadPosting")
  driver                       Driver?
  fleetOwner                   FleetOwner?
  orderer                      Orderer?

  @@map("users")
}

model FleetOwner {
  id                         String      @id @db.VarChar(26)
  userId                     String      @unique @map("user_id")
  companyName                String?     @map("company_name")
  companyNameAmharic         String?     @map("company_name_amharic")
  tinNumber                  String?     @map("tin_number")
  bankName                   String?     @map("bank_name")
  bankAccountNumber          String?     @map("bank_account_number")
  mobileMoneyNumber          String?     @map("mobile_money_number")
  preferredPayoutMethod      String      @default("BANK") @map("preferred_payout_method")
  trustScore                 Decimal     @default(50.00) @map("trust_score") @db.Decimal(5, 2)
  trustTier                  Int         @default(0) @map("trust_tier")
  payoutSpeed                String      @default("T0") @map("payout_speed")
  creditLimitEtb             Decimal     @default(0) @map("credit_limit_etb") @db.Decimal(12, 2)
  isCreditEligible           Boolean     @default(false) @map("is_credit_eligible")
  regionAccess               String[]    @default([]) @map("region_access")
  loadWeightTier             Int         @default(1) @map("load_weight_tier")
  totalTripsCompleted        Int         @default(0) @map("total_trips_completed")
  totalRevenueEtb            Decimal     @default(0) @map("total_revenue_etb") @db.Decimal(12, 2)
  paymentReliabilityScore    Decimal     @default(50.00) @map("payment_reliability_score") @db.Decimal(5, 2)
  fleetSize                  Int?        @map("fleet_size")
  businessType               String?     @map("business_type")
  yearsInBusiness            Int?        @map("years_in_business")
  primaryCorridors           String[]    @map("primary_corridors")
  reinvestmentRate           Decimal?    @map("reinvestment_rate") @db.Decimal(5, 2)
  businessRegistrationNumber String?     @map("business_registration_number")
  tradeLicenseExpiry         DateTime?   @map("trade_license_expiry")
  cbeBankAccount             String?     @map("cbe_bank_account")
  monthlyRevenueEstimate     Int?        @map("monthly_revenue_estimate")
  kycTier                    Int         @default(0) @map("fleet_kyc_tier")
  deletedAt                  DateTime?   @map("deleted_at")
  createdAt                  DateTime    @default(now()) @map("created_at")
  updatedAt                  DateTime    @updatedAt @map("updated_at")
  isRestricted               Boolean     @default(false) @map("is_restricted")
  expenses                   Expense[]
  loans                      FleetLoan[]
  user                       User        @relation(fields: [userId], references: [id])
  trucks                     Truck[]

  @@map("fleet_owners")
}

model Orderer {
  id                         String         @id @db.VarChar(26)
  userId                     String         @unique @map("user_id")
  companyName                String?        @map("company_name")
  companyNameAmharic         String?        @map("company_name_amharic")
  tinNumber                  String?        @map("tin_number")
  businessSector             String?        @map("business_sector")
  bankName                   String?        @map("bank_name")
  bankAccountNumber          String?        @map("bank_account_number")
  mobileMoneyNumber          String?        @map("mobile_money_number")
  preferredPaymentMethod     String         @default("ESCROW") @map("preferred_payment_method")
  paymentTermsDays           Int            @default(0) @map("payment_terms_days")
  creditScore                Decimal        @default(50.00) @map("credit_score") @db.Decimal(5, 2)
  creditLimitEtb             Decimal        @default(0) @map("credit_limit_etb") @db.Decimal(12, 2)
  isCreditEligible           Boolean        @default(false) @map("is_credit_eligible")
  paymentReliabilityScore    Decimal        @default(50.00) @map("payment_reliability_score") @db.Decimal(5, 2)
  avgLeadTimeDays            Decimal?       @map("avg_lead_time_days") @db.Decimal(4, 1)
  priceSensitivityScore      Decimal?       @map("price_sensitivity_score") @db.Decimal(5, 2)
  preferredTruckTypes        String[]       @default([]) @map("preferred_truck_types")
  seasonalPattern            String?        @map("seasonal_pattern")
  totalLoadsCreated          Int            @default(0) @map("total_loads_created")
  totalSpendEtb              Decimal        @default(0) @map("total_spend_etb") @db.Decimal(12, 2)
  businessRegistrationNumber String?        @map("business_registration_number")
  industrySector             String?        @map("industry_sector")
  monthlyFreightSpend        Int?           @map("monthly_freight_spend")
  creditLineApproved         Boolean        @default(false) @map("credit_line_approved")
  creditLineLimitEtb         Int            @default(0) @map("credit_line_limit_etb")
  preferredTruckBodyTypes    String[]       @default([]) @map("preferred_truck_body_types")
  apiAccessEnabled           Boolean        @default(false) @map("api_access_enabled")
  webhookUrl                 String?        @map("webhook_url")
  kycTier                    Int            @default(0) @map("orderer_kyc_tier")
  deletedAt                  DateTime?      @map("deleted_at")
  createdAt                  DateTime       @default(now()) @map("created_at")
  updatedAt                  DateTime       @updatedAt @map("updated_at")
  apiKeys                    ApiKey[]
  loadStops                  LoadStop[]
  templates                  LoadTemplate[]
  loads                      Load[]
  user                       User           @relation(fields: [userId], references: [id])

  @@map("orderers")
}

model Driver {
  id                       String    @id @db.VarChar(26)
  userId                   String    @unique @map("user_id")
  fleetOwnerId             String?   @map("fleet_owner_id")
  licenseNumber            String    @map("license_number")
  licenseClass             String?   @map("license_class")
  licenseExpiry            DateTime? @map("license_expiry")
  trustScore               Decimal   @default(50.00) @map("trust_score") @db.Decimal(5, 2)
  trustTier                Int       @default(0) @map("trust_tier")
  status                   String    @default("ACTIVE")
  onTimeRate               Decimal   @default(0) @map("on_time_rate") @db.Decimal(5, 2)
  disputeCount30d          Int       @default(0) @map("dispute_count_30d")
  disputeCount90d          Int       @default(0) @map("dispute_count_90d")
  deviationRate            Decimal   @default(0) @map("deviation_rate") @db.Decimal(5, 2)
  cancellationRate         Decimal   @default(0) @map("cancellation_rate") @db.Decimal(5, 2)
  incidentCount90d         Int       @default(0) @map("incident_count_90d")
  anomalyFlagCount         Int       @default(0) @map("anomaly_flag_count")
  totalTripsCompleted      Int       @default(0) @map("total_trips_completed")
  consecutiveCleanTrips    Int       @default(0) @map("consecutive_clean_trips")
  codDiscrepancyCount      Int       @default(0) @map("cod_discrepancy_count")
  codTripsTotal            Int       @default(0) @map("cod_trips_total")
  homeCity                 String?   @map("home_city")
  preferredCorridors       String[]  @map("preferred_corridors")
  routeFamiliarityScore    Json?     @map("route_familiarity_score")
  avgResponseTimeMin       Decimal?  @map("avg_response_time_min") @db.Decimal(4, 1)
  typicalRestDurationH     Decimal?  @map("typical_rest_duration_h") @db.Decimal(3, 1)
  preferredAssignmentHour  Int?      @map("preferred_assignment_hour")
  homeBaseCityId           String?   @map("home_base_city_id")
  preferredCorridorIds     String[]  @default([]) @map("preferred_corridor_ids")
  availabilityStatus       String    @default("AVAILABLE") @map("availability_status")
  licenseCategory          String?   @map("license_category")
  emergencyContactName     String?   @map("emergency_contact_name")
  emergencyContactPhone    String?   @map("emergency_contact_phone")
  telebirrNumber           String?   @map("telebirr_number")
  deletedAt                DateTime? @map("deleted_at")
  createdAt                DateTime  @default(now()) @map("created_at")
  updatedAt                DateTime  @updatedAt @map("updated_at")
  averageRating            Decimal   @default(5.0) @map("average_rating") @db.Decimal(3, 2)
  currentLat               Decimal?  @map("current_lat") @db.Decimal(10, 6)
  currentLng               Decimal?  @map("current_lng") @db.Decimal(10, 6)
  currentZoneId            String?   @map("current_zone_id")
  drivingHoursToday        Decimal   @default(0) @map("driving_hours_today") @db.Decimal(4, 1)
  hasSmartphone            Boolean   @default(true) @map("has_smartphone")
  homeZoneId               String?   @map("home_zone_id")
  languagesSpoken          String[]  @default([]) @map("languages_spoken")
  lastDrivingHoursReset    DateTime? @map("last_driving_hours_reset")
  onTimeDeliveryRate       Decimal   @default(1.0) @map("on_time_delivery_rate") @db.Decimal(3, 2)
  preferredZoneIds         String[]  @default([]) @map("preferred_zone_ids")
  shiftEndsAt              DateTime? @map("shift_ends_at")
  shiftStartsAt            DateTime? @map("shift_starts_at")
  totalKmDriven            Int       @default(0) @map("total_km_driven")
  totalTripsCompletedCount Int       @default(0) @map("total_trips_completed_count")
  deviceFingerprint        String?   @map("device_fingerprint")
  faceVerificationHash     String?   @map("face_verification_hash")
  faceVerifiedAt           DateTime? @map("face_verified_at")
  homeZoneRegistered       String?   @map("home_zone_registered")
  multiSimPaymentPhone     String?   @map("multi_sim_payment_phone")
  multiSimPrimaryPhone     String?   @map("multi_sim_primary_phone")
  currentZone              Zone?     @relation("DriverCurrentZone", fields: [currentZoneId], references: [id])
  homeZone                 Zone?     @relation("DriverHomeZone", fields: [homeZoneId], references: [id])
  user                     User      @relation(fields: [userId], references: [id])
  trips                    Trip[]

  @@map("drivers")
}

model Truck {
  id                              String             @id @db.VarChar(26)
  plateNumber                     String             @unique @map("plate_number")
  fleetOwnerId                    String?            @map("fleet_owner_id")
  currentDriverId                 String?            @map("current_driver_id")
  make                            String?
  model                           String?
  year                            Int?
  truckType                       String             @map("truck_type")
  capacityKg                      Int                @map("capacity_kg")
  capacityCbm                     Decimal?           @map("capacity_cbm") @db.Decimal(8, 2)
  axleCount                       Int?               @map("axle_count")
  status                          String             @default("ACTIVE")
  insurancePolicyNumber           String?            @map("insurance_policy_number")
  insuranceExpiry                 DateTime?          @map("insurance_expiry")
  annualInspectionExpiry          DateTime?          @map("annual_inspection_expiry")
  roadWorthinessExpiry            DateTime?          @map("road_worthiness_expiry")
  fuelConsumptionLp100km          Decimal?           @map("fuel_consumption_lp100km") @db.Decimal(4, 1)
  fuelTankCapacityL               Int?               @map("fuel_tank_capacity_l")
  odometerKm                      Int                @default(0) @map("odometer_km")
  engineHours                     Int                @default(0) @map("engine_hours")
  lastMaintenanceKm               Int?               @map("last_maintenance_km")
  lastMaintenanceAt               DateTime?          @map("last_maintenance_at")
  hasBankLoan                     Boolean            @default(false) @map("has_bank_loan")
  loanBankName                    String?            @map("loan_bank_name")
  coOwnerUserId                   String?            @map("co_owner_user_id")
  coOwnerSharePct                 Decimal?           @map("co_owner_share_pct") @db.Decimal(5, 2)
  libreNumber                     String?            @map("libre_number")
  chassisNumber                   String?            @map("chassis_number")
  engineNumber                    String?            @map("engine_number")
  manufacturingYear               Int?               @map("manufacturing_year")
  bodyType                        String             @default("FLATBED") @map("body_type")
  payloadQuintals                 Decimal?           @map("payload_quintals") @db.Decimal(10, 2)
  insuranceCompany                String?            @map("insurance_company")
  insuranceType                   String             @default("THIRD_PARTY") @map("insurance_type")
  inspectionNumber                String?            @map("inspection_number")
  inspectionExpiry                DateTime?          @map("inspection_expiry")
  odometer                        Int                @default(0) @map("odometer_reading")
  lastServiceDate                 DateTime?          @map("last_service_date")
  nextServiceDate                 DateTime?          @map("next_service_date")
  kycTier                         Int                @default(0) @map("truck_kyc_tier")
  isEligibleForLoads              Boolean            @default(false) @map("is_eligible_for_loads")
  deletedAt                       DateTime?          @map("deleted_at")
  createdAt                       DateTime           @default(now()) @map("created_at")
  updatedAt                       DateTime           @updatedAt @map("updated_at")
  availableAtLat                  Decimal?           @map("available_at_lat") @db.Decimal(10, 6)
  availableAtLng                  Decimal?           @map("available_at_lng") @db.Decimal(10, 6)
  availableFromAt                 DateTime?          @map("available_from_at")
  averageFuelConsumptionLper100km Decimal?           @map("average_fuel_consumption_lper100km") @db.Decimal(5, 2)
  currentLat                      Decimal?           @map("current_lat") @db.Decimal(10, 6)
  currentLng                      Decimal?           @map("current_lng") @db.Decimal(10, 6)
  currentZoneId                   String?            @map("current_zone_id")
  grossVehicleWeightKg            Int?               @map("gross_vehicle_weight_kg")
  homeZoneId                      String?            @map("home_zone_id")
  lastKnownOdometerKm             Int?               @map("last_known_odometer_km")
  legalPayloadKg                  Int?               @map("legal_payload_kg")
  manufactureYear                 Int?               @map("manufacture_year")
  nextServiceDueKm                Int?               @map("next_service_due_km")
  preferredCorridorIds            String[]           @default([]) @map("preferred_corridor_ids")
  truckBrand                      TruckBrand         @default(OTHER) @map("truck_brand")
  truckModelDetail                String?            @map("truck_model_detail")
  fuelType                        FuelType           @default(DIESEL) @map("fuel_type")
  isPrivateFleet                  Boolean            @default(false) @map("is_private_fleet")
  marketplaceAvailable            Boolean            @default(true) @map("marketplace_available")
  privateFleetOwnerId             String?            @map("private_fleet_owner_id") @db.VarChar(26)
  trips                           Trip[]
  maintenance                     TruckMaintenance[]
  currentZone                     Zone?              @relation("TruckCurrentZone", fields: [currentZoneId], references: [id])
  fleetOwner                      FleetOwner?        @relation(fields: [fleetOwnerId], references: [id])
  homeZone                        Zone?              @relation("TruckHomeZone", fields: [homeZoneId], references: [id])

  @@map("trucks")
}

model KycDocument {
  id              String    @id @db.VarChar(26)
  entityId        String    @map("entity_id")
  entityType      String    @map("entity_type")
  docType         String    @map("doc_type")
  s3Key           String    @map("s3_key")
  s3Bucket        String    @map("s3_bucket")
  fileSizeBytes   Int?      @map("file_size_bytes")
  status          String    @default("PENDING")
  expiryDate      DateTime? @map("expiry_date")
  rejectionReason String?   @map("rejection_reason")
  reviewedBy      String?   @map("reviewed_by")
  reviewedAt      DateTime? @map("reviewed_at")
  deletedAt       DateTime? @map("deleted_at")
  createdAt       DateTime  @default(now()) @map("created_at")

  @@map("kyc_documents")
}

model Corridor {
  id                       String       @id @db.VarChar(26)
  name                     String
  nameAmharic              String?      @map("name_amharic")
  originCity               String       @map("origin_city")
  destinationCity          String       @map("destination_city")
  distanceKm               Int          @map("distance_km")
  region                   String
  status                   String       @default("ACTIVE")
  healthScore              Decimal      @default(50) @map("health_score") @db.Decimal(5, 2)
  densityIndex             Decimal      @default(0) @map("density_index") @db.Decimal(5, 2)
  expansionEligible        Boolean      @default(false) @map("expansion_eligible")
  loadToTruckRatio         Decimal      @default(0) @map("load_to_truck_ratio") @db.Decimal(5, 2)
  backhaulPct              Decimal      @default(0) @map("backhaul_pct") @db.Decimal(5, 2)
  siuInvested              Int          @default(0) @map("siu_invested")
  siuRoi                   Decimal      @default(0) @map("siu_roi") @db.Decimal(5, 2)
  roadType                 String?      @map("road_type")
  hasMountainPass          Boolean      @default(false) @map("has_mountain_pass")
  floodRiskMonths          String[]     @map("flood_risk_months")
  createdAt                DateTime     @default(now()) @map("created_at")
  averageTransitMinutes    Int?         @map("average_transit_minutes")
  checkpointCount          Int          @default(0) @map("checkpoint_count")
  corridorType             CorridorType @default(INTERCITY) @map("corridor_type")
  destinationZoneId        String?      @map("destination_zone_id")
  expectedCheckpointFeeEtb Int          @default(0) @map("expected_checkpoint_fee_etb")
  isNightTimeRestricted    Boolean      @default(false) @map("is_night_time_restricted")
  nightRestrictionReason   String?      @map("night_restriction_reason")
  originZoneId             String?      @map("origin_zone_id")
  peakHourMultiplier       Decimal      @default(1.0) @map("peak_hour_multiplier") @db.Decimal(3, 2)
  roadConditionScore       Int          @default(100) @map("road_condition_score")
  seasonalClosureMonths    Int[]        @default([]) @map("seasonal_closure_months")
  destinationZone          Zone?        @relation("CorridorDestZone", fields: [destinationZoneId], references: [id])
  originZone               Zone?        @relation("CorridorOriginZone", fields: [originZoneId], references: [id])

  @@map("corridors")
}

model Load {
  id                       String        @id @db.VarChar(26)
  ordererId                String        @map("orderer_id")
  agentId                  String?       @map("agent_id") @db.VarChar(26)
  corridorId               String        @map("corridor_id")
  originCity               String        @map("origin_city")
  originAddress            String?       @map("origin_address")
  originGeoLat             Decimal?      @map("origin_geo_lat") @db.Decimal(10, 6)
  originGeoLng             Decimal?      @map("origin_geo_lng") @db.Decimal(10, 6)
  destinationCity          String        @map("destination_city")
  destinationAddress       String?       @map("destination_address")
  destinationGeoLat        Decimal?      @map("destination_geo_lat") @db.Decimal(10, 6)
  destinationGeoLng        Decimal?      @map("destination_geo_lng") @db.Decimal(10, 6)
  isMultiStop              Boolean       @default(false) @map("is_multi_stop")
  waypoints                Json?
  cargoType                String        @map("cargo_type")
  cargoDescription         String?       @map("cargo_description")
  weightKg                 Int           @map("weight_kg")
  volumeCbm                Decimal?      @map("volume_cbm") @db.Decimal(8, 2)
  requiresReefer           Boolean       @default(false) @map("requires_reefer")
  hazmatClass              String?       @map("hazmat_class")
  specialInstructions      String?       @map("special_instructions")
  pickupDate               DateTime      @map("pickup_date")
  deliveryDeadline         DateTime      @map("delivery_deadline")
  urgencyLevel             Int           @default(2) @map("urgency_level")
  systemQuoteEtb           Decimal?      @map("system_quote_etb") @db.Decimal(12, 2)
  finalRateEtb             Decimal?      @map("final_rate_etb") @db.Decimal(12, 2)
  ruitCommissionEtb        Decimal?      @map("ruit_commission_etb") @db.Decimal(12, 2)
  fleetPayoutEtb           Decimal?      @map("fleet_payout_etb") @db.Decimal(12, 2)
  paymentModel             String        @default("ESCROW") @map("payment_model")
  status                   String        @default("DRAFT")
  strategyVersionId        String        @map("strategy_version_id")
  ethiopianCalendarEvent   String?       @map("ethiopian_calendar_event")
  weatherCondition         String?       @map("weather_condition")
  bookingLeadTimeHours     Int?          @map("booking_lead_time_hours")
  ordererRequestSource     String        @default("APP") @map("orderer_request_source")
  loadType                 String        @default("SIMPLE") @map("load_type")
  preferredTruckBodyType   String?       @map("preferred_truck_body_type")
  requiresRefrigeration    Boolean       @default(false) @map("requires_refrigeration")
  isHazardous              Boolean       @default(false) @map("is_hazardous")
  insuranceRequired        Boolean       @default(false) @map("insurance_required")
  idempotencyKey           String?       @unique @map("idempotency_key")
  templateId               String?       @map("template_id")
  totalStops               Int           @default(2) @map("total_stops")
  fuelAdvanceAmount        Int           @default(0) @map("fuel_advance_amount")
  fuelAdvanceApproved      Boolean       @default(false) @map("fuel_advance_approved")
  deletedAt                DateTime?     @map("deleted_at")
  createdAt                DateTime      @default(now()) @map("created_at")
  updatedAt                DateTime      @updatedAt @map("updated_at")
  currentLat               Decimal?      @map("current_lat") @db.Decimal(10, 6)
  currentLng               Decimal?      @map("current_lng") @db.Decimal(10, 6)
  lastLocationAt           DateTime?     @map("last_location_at")
  lastPingSource           String?       @map("last_ping_source")
  actualDeliveryAt         DateTime?     @map("actual_delivery_at")
  actualPickupAt           DateTime?     @map("actual_pickup_at")
  deliveryZoneId           String?       @map("delivery_zone_id")
  expectedLoadingMinutes   Int?          @map("expected_loading_minutes")
  expectedUnloadingMinutes Int?          @map("expected_unloading_minutes")
  fastTrack                Boolean       @default(false) @map("fast_track")
  isRecurring              Boolean       @default(false) @map("is_recurring")
  overloadWarningIssued    Boolean       @default(false) @map("overload_warning_issued")
  pickupZoneId             String?       @map("pickup_zone_id")
  templateReferenceId      String?       @map("template_reference_id")
  totalCheckpointFeesEtb   Int           @default(0) @map("total_checkpoint_fees_etb")
  urgencyLevelEnum         String?       @map("urgency_level_enum")
  directBookingId          String?       @map("direct_booking_id") @db.VarChar(26)
  source                   String?       @default("MANUAL") @map("source")
  harvestDeclaredAt        DateTime?     @map("harvest_declared_at")
  isTimeCritical           Boolean       @default(false) @map("is_time_critical")
  livestockAgeClass        String?       @map("livestock_age_class")
  livestockDeliveredAlive  Int?          @map("livestock_delivered_alive")
  livestockHeadCount       Int?          @map("livestock_head_count")
  livestockSpecies         String?       @map("livestock_species")
  paymentBasis             String?       @map("payment_basis")
  timeCriticalEscalated    Boolean       @default(false) @map("time_critical_escalated")
  vetCertificateUrl        String?       @map("vet_certificate_url")
  insuranceAccepted        Boolean       @default(false) @map("insurance_accepted")
