/**
 * RUIT CBE - Engine 4: COD Service
 * Manages Cash on Delivery logging and verification
 */

import { prisma as db } from '@ruit/shared-db';
import { releaseEscrow } from './escrow.service.js';

interface LogCODParams {
  loadId: string;
  tripId: string;
  ordererId: string;
  fleetOwnerId: string;
  expectedAmountEtb: number;
  codHandler: 'DRIVER' | 'RUIT_AGENT' | 'DIRECT';
  collectedByUserId?: string | undefined;
  actorId: string;
}

interface VerifyCODParams {
  transactionId: string;
  verified: boolean;
  collectedEtb: number;
  actorId: string;
  notes?: string | undefined;
}

/**
 * Emit an event (placeholder - should call event service)
 */
async function emitEvent(eventType: string, payload: Record<string, unknown>): Promise<void> {
  console.log(`Event emitted: ${eventType}`, payload);
}

/**
 * Log a COD transaction
 * Creates a COD_LOG financial transaction
 */
export async function logCOD(params: LogCODParams): Promise<{ transactionId: string }> {
  // Generate ULID-like ID
  const timestamp = Date.now().toString(36).toUpperCase();
  const random = Math.random().toString(36).substring(2, 8).toUpperCase();
  const transactionId = `ftx${timestamp}${random}`;

    // Create COD_LOG transaction
    await db.financialTransaction.create({
      data: {
        id: transactionId,
        loadId: params.loadId,
        tripId: params.tripId,
        ordererId: params.ordererId,
        fleetOwnerId: params.fleetOwnerId,
        txType: 'COD_LOG',
        amountEtb: params.expectedAmountEtb,
        direction: 'IN',
        status: 'PENDING',
        paymentModel: 'COD',
        codHandler: params.codHandler,
        codCollectedByUserId: params.collectedByUserId ?? null,
        // If RUIT_AGENT handled it, auto-verify
        codVerified: params.codHandler === 'RUIT_AGENT' ? true : null
      }
    });

  return { transactionId };
}

/**
 * Verify a COD transaction
 * Handles discrepancies and triggers escrow release on verification
 */
export async function verifyCOD(params: VerifyCODParams): Promise<void> {
  await db.$transaction(async (tx) => {
    // Get the COD_LOG transaction
    const codTx = await tx.financialTransaction.findUnique({
      where: { id: params.transactionId }
    });

    if (!codTx || codTx.txType !== 'COD_LOG') {
      throw new Error('COD_TRANSACTION_NOT_FOUND');
    }

    // Update the transaction
    await tx.financialTransaction.update({
      where: { id: params.transactionId },
      data: {
        codVerified: params.verified,
        codCollectedAt: new Date(),
        status: params.verified ? 'COMPLETED' : 'DISPUTED'
      }
    });

    const expectedAmount = Number(codTx.amountEtb);
    const hasDiscrepancy = !params.verified || params.collectedEtb !== expectedAmount;

    // Handle discrepancy
    if (hasDiscrepancy) {
      // Emit COD_DISCREPANCY_REPORTED event
      await emitEvent('COD_DISCREPANCY_REPORTED', {
        transactionId: params.transactionId,
        tripId: codTx.tripId,
        expectedAmount,
        collectedAmount: params.collectedEtb,
        verified: params.verified,
        actorId: params.actorId,
        notes: params.notes
      });

      // Increment driver cod_discrepancy_count if driver collected
      if (codTx.codCollectedByUserId) {
        await tx.$executeRaw`UPDATE drivers 
          SET cod_discrepancy_count = cod_discrepancy_count + 1,
              updated_at = NOW()
          WHERE user_id = ${codTx.codCollectedByUserId}`;
      }
    }

    // Increment driver's total COD trips
    if (codTx.codCollectedByUserId) {
      await tx.$executeRaw`UPDATE drivers 
        SET cod_trips_total = cod_trips_total + 1,
            updated_at = NOW()
        WHERE user_id = ${codTx.codCollectedByUserId}`;
    }

    // If verified, trigger escrow release
    if (params.verified && codTx.loadId && codTx.tripId) {
      await releaseEscrow({
        loadId: codTx.loadId,
        tripId: codTx.tripId,
        actorId: params.actorId,
        actorRole: 'FINANCE_OPS'
      });
    }
  });
}
