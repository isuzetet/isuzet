{
  "root": true,
  "env": {
    "node": true,
    "browser": true,
    "es2022": true
  },
  "parser": "@typescript-eslint/parser",
  "parserOptions": { "ecmaVersion": 2022, "sourceType": "module" },
  "extends": ["eslint:recommended"],
  "ignorePatterns": ["node_modules/", "dist/"],
  "rules": {
    "no-unused-vars": "warn"
  }
}
